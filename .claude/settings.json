{
  "autoMemoryEnabled": false,
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "stigmergy hook claim-guard",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|NotebookEdit"
      },
      {
        "hooks": [
          {
            "command": "stigmergy hook root-gate",
            "type": "command"
          }
        ],
        "matcher": "mcp__stigmergy__(root_register|root_heartbeat|root_deregister|memory_write|memory_promote|memory_delete|claim_acquire|claim_renew|claim_release|mailbox_.*)"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "stigmergy hook session-end",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "stigmergy hook session-start",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "stigmergy hook mail-gate",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "stigmergy hook mail-notify",
            "type": "command"
          }
        ]
      }
    ]
  }
}
